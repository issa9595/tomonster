# ─────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────
MONGODB_HOST=cluster0.xxxxx.mongodb.net
MONGODB_DATABASE_NAME=tamagotcho
MONGODB_USERNAME=your_username
MONGODB_PASSWORD=your_password
MONGODB_APP_NAME=tamagotcho
MONGODB_PARAMS=retryWrites=true&w=majority

# ─────────────────────────────────────────
# Better Auth
# ─────────────────────────────────────────
BETTER_AUTH_SECRET=your_random_secret_32_chars_minimum
BETTER_AUTH_URL=http://localhost:3000

# ─────────────────────────────────────────
# GitHub OAuth
# (créer une OAuth App sur github.com/settings/developers)
# ─────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ─────────────────────────────────────────
# Stripe
# (clés disponibles sur dashboard.stripe.com)
# ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────
# Cron (généré automatiquement par Vercel en production)
# En local : mettre n'importe quelle valeur pour tester
# ─────────────────────────────────────────
CRON_SECRET=your_cron_secret
